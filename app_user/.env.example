GOOGLE_MAPS_ANDROID_API_KEY=
GOOGLE_MAPS_IOS_API_KEY=

# Mapbox (@rnmapbox/maps) — TWO distinct tokens, do not mix them up:
#   MAPBOX_DOWNLOAD_TOKEN: secret "sk." token, BUILD-TIME only (config plugin
#     downloads the native SDK). Never prefix with EXPO_PUBLIC_ and never commit.
#   EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN: public "pk." token, RUNTIME (read by JS in
#     Mapbox.setAccessToken to load tiles). EXPO_PUBLIC_ so it reaches the JS bundle.
MAPBOX_DOWNLOAD_TOKEN=
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=