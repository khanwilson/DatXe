# ============================================
# Database - PostgreSQL
# ============================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nest_auth?schema=public"
DATABASE_PORT=5432

# ============================================
# Redis
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# JWT - Access & Refresh Tokens
# NOTE: JWT_SECRET is legacy, kept for backward compat with auth module.
# T-0006 will migrate auth module to use JWT_ACCESS_TOKEN_* and JWT_REFRESH_TOKEN_*.
# ============================================
JWT_SECRET="change-me-in-production"
JWT_ACCESS_TOKEN_SECRET="change-me-in-production-access"
JWT_ACCESS_TOKEN_EXPIRATION=7d
JWT_REFRESH_TOKEN_SECRET="change-me-in-production-refresh"
JWT_REFRESH_TOKEN_EXPIRATION=30d

# ============================================
# API
# ============================================
API_PREFIX=api/v1
API_PORT=3000

# ============================================
# CORS
# ============================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8081
CORS_CREDENTIALS=true

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ============================================
# Google Maps API - Routes Service (T-0031)
# ============================================
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_MAPS_BASE_URL=https://maps.googleapis.com/maps/api
